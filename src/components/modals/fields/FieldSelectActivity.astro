---
const { label, model } = Astro.props
const activities = [
  'Hiking', 'Biking', 'Boating', 'Offroad', 'Motorcycling',
  'Flying', 'Skiing', 'Snowshoeing', 'Getting There'
]
---

<div class="field is-horizontal"
     x-data={`{ model: '${model}' }`}>

  <div
    class="field-label is-normal"
    :id="`${idPrefix}-${model}-label`"
  >
    {label}
  </div>

  <div class="field-body">
    <div class="field">
      <div class="control">
        <div class="select">

          <select
            :id="`${idPrefix}-${model}`"
            :aria-labelledby="`${idPrefix}-${model}-label`"
            x-model={model}
          >
            {activities.map(a => <option>{a}</option>)}
          </select>

        </div>
      </div>
    </div>
  </div>
</div>
