---
import '../../styles/vendor/bulma-switch-control/main.min.css'
import ModalHeader from './parts/ModalHeader.astro'
import ModalFooterMessages from './parts/ModalFooterMessages.astro'
import FieldText from './fields/FieldText.astro'
import FieldTextarea from './fields/FieldTextarea.astro'
import FieldSwitch from './fields/FieldSwitch.astro'
import FieldDifficulty from './fields/FieldDifficulty.astro'
import FieldSelectActivity from './fields/FieldSelectActivity.astro'
import FieldSelectRegion from './fields/FieldSelectRegion.astro'
import PhotosPanel from './parts/PhotosPanel.astro'
---

<div x-data>
	<div class="modal modal-top" :class="{ 'is-active': $store.ui.showUploadTrackModal }">

        <div class="modal-background"
             @click="$store.ui.showUploadTrackModal = false"></div>

        <div class="modal-card upload-track-modal-card" x-data="uploadTrackModal" x-init="idPrefix = 'upload'">

			<ModalHeader closeAction="$store.ui.showUploadTrackModal = false">
				<p slot="title" class="is-size-5 mb-2">Upload a Track</p>
				<p slot="subtitle" class="is-size-6 mr-2">
					Provide track information and optional photos…
				</p>
			</ModalHeader>

            <!-- BODY -->
            <section class="modal-card-body">

                <!-- TABS -->
                <div class="tabs is-boxed">
                    <ul>
                        <li :class="{ 'is-active': tab === 'info' }">
                            <a @click="tab = 'info'">Info</a>
                        </li>
						<li x-show="trackGPXBlob"
							:class="{ 'is-active': tab === 'photos' }">
							<a @click="tab = 'photos'">Photos</a>
						</li>
                    </ul>
                </div>

				<!-- INFO TAB -->
				<div x-show="tab === 'info'">
					<div>

						<!-- GPX FILE + REGION OVERRIDE IN ONE ROW -->
						<div class="field is-horizontal">

							<!-- LEFT LABEL FOR GPX -->
							<label class="field-label is-normal">GPX file</label>

							<div class="field-body">

								<!-- GPX FILE INPUT -->
								<div class="field">
									<div class="control">
										<input class="input"
											type="file"
											accept=".gpx"
											x-ref="gpxInput"
											@change="selectGpxFile($event)"
											:class="{ 'is-danger': $store.ui.errorField === 'gpxFile' }">
									</div>
									<p class="help is-size-7">Up to 4MB</p>
								</div>

								<!-- REGION SELECTOR (NESTED HORIZONTAL FIELD) -->
								<FieldSelectRegion
									label="Region"
									model="selectedRegionOverride"
									options="regionOverrideOptions"
								/>

							</div>
						</div>

						<!-- TRACK NAME -->
						<FieldText label="Name" model="trackName" errorName="trackName" placeholder="Track name" />
						<!-- DESCRIPTION -->
						<FieldTextarea label="Description" model="trackDescription" errorName="trackDescription" placeholder="Track description" />
						<!-- FAVORITE -->
						<FieldSwitch label="Favorite?" model="trackFav" />
						<!-- DIFFICULTY -->
						<FieldDifficulty label="Difficulty" model="trackLevel" />
						<!-- ACTIVITY -->
						<FieldSelectActivity label="Activity" model="trackType" />
					</div>
				</div>
                <!-- PHOTOS TAB -->
				 <template x-if="tab === 'photos' && trackGPXBlob">
					<PhotosPanel />
				 </template>

				<div class="field is-horizontal mt-4">
					<div class="field-label"></div>
					<div class="field-body">
						<div class="field">
							<div class="control">
								<button class="button"
										:disabled="$store.ui.uploading"
										@click="upload()">
									Upload
								</button>
							</div>
						</div>
					</div>
				</div>

            </section>

			<ModalFooterMessages />

        </div>
    </div>
</div>

<style>
    /* Header wrapping fix */
    .modal-card-head {
        align-items: flex-start;
    }

    .modal-card-head .modal-card-title {
        flex: 1 1 0;
        min-width: 0;
        white-space: normal;
    }

    /* B — Align-bottom utility */
    .align-bottom {
        display: flex;
        align-items: flex-end;
    }

    /* C — Modal max-height for mobile */
    .modal .modal-card {
        max-height: calc(100vh - 7rem);
        overflow-y: auto;
    }

    /* Label alignment */
    /*.field-label {
        flex-basis: 4rem;
    }*/

    /* Top-align modal */
    .modal.modal-top .modal-card {
        margin-top: 1.5rem;
        margin-bottom: auto;
    }

    /* Default: mobile (1 per row) */
    .upload-track-modal-card {
        width: 90vw !important;
        max-width: 90vw !important;
    }

    /* ≥ 768px: wider modal */
    @media screen and (min-width: 768px) {
        .upload-track-modal-card {
            width: 60rem !important;
            max-width: 90vw !important;
        }
    }

    /* ≥ 1024px: widest modal */
    @media screen and (min-width: 1024px) {
        .upload-track-modal-card {
            width: 60rem !important;
            max-width: 90vw !important;
        }
    }

	/* Reduce column gap inside the upload modal */
	.upload-track-modal-card .columns {
		--bulma-column-gap: 0.3rem;
	}

</style>


